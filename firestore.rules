rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function hasValidUserProfileData(userId) {
      return request.resource.data.userId == userId;
    }

    function isImmutableUserId() {
      return request.resource.data.userId == resource.data.userId;
    }

    function hasValidSubcollectionData(userProfileId) {
      return request.resource.data.profileId == userProfileId;
    }

    function isImmutableProfileId() {
      return request.resource.data.profileId == resource.data.profileId;
    }

    // =====================================================================
    // Data Rules
    // =====================================================================

    // All user-owned data is nested under /users/{userId}
    match /users/{userId} {
      // Basic user document access
      allow get, create, update, delete: if isOwner(userId);

      // User Profiles Collection
      // Path: /users/{userId}/userProfiles/{userProfileId}
      match /userProfiles/{userProfileId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidUserProfileData(userId);
        allow update: if isExistingOwner(userId) && isImmutableUserId();
        allow delete: if isExistingOwner(userId);

        // Subcollections must be nested HERE to inherit {userId} and {userProfileId}
        
        // Incomes
        match /incomes/{incomeId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidSubcollectionData(userProfileId);
          allow update: if isExistingOwner(userId) && isImmutableProfileId();
          allow delete: if isExistingOwner(userId);
        }

        // Expenses
        match /expenses/{expenseId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidSubcollectionData(userProfileId);
          allow update: if isExistingOwner(userId) && isImmutableProfileId();
          allow delete: if isExistingOwner(userId);
        }

        // Savings Accounts
        match /savingsAccounts/{savingsAccountId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidSubcollectionData(userProfileId);
          allow update: if isExistingOwner(userId) && isImmutableProfileId();
          allow delete: if isExistingOwner(userId);
        }

        // Debts
        match /debts/{debtId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidSubcollectionData(userProfileId);
          allow update: if isExistingOwner(userId) && isImmutableProfileId();
          allow delete: if isExistingOwner(userId);
        }

        // Transactions
        match /transactions/{transactionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidSubcollectionData(userProfileId);
          allow update: if isExistingOwner(userId) && isImmutableProfileId();
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}